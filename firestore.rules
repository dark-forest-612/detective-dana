rules_version = '2';

// Phase 4 draft. Deploy with `firebase deploy --only firestore:rules`.
//
// There is still no Firebase Auth and no App Check — these rules enforce
// *cooperative* locking only. A malicious client can spoof `lock.holder`
// and bypass the protection. Acceptable for the ~5-trusted-user target
// as long as App Check + Auth land in Phase 5 before the project is
// exposed to untrusted traffic.
//
// The rules prevent the everyday accident case: two clients writing to
// the same note within the TTL window, either because one ignored the
// UI banner or because of a lost `releaseLock` ping.
//
// NOTE: This file is generated from firestore.rules.template by
// `scripts/generate-firestore-rules.mjs`. Edit the template, not this
// file.
//
// Collection names come from (in precedence order):
//   1. FIREBASE_RULES_{NOTES,APP_SETTINGS}_COLLECTIONS — comma-separated
//      list. Use when multiple projects share one database and each owns
//      a distinct collection name; every name gets its own match block.
//   2. PUBLIC_FIREBASE_{NOTES,APP_SETTINGS}_COLLECTION — singular, same
//      var the client reads. Used when the rules list is unset.
//   3. Defaults: `notes`, `appSettings`.

service cloud.firestore {
	match /databases/{database}/documents {
		match /notes_chunseek/{guid} {
			allow read: if true;

			// New note: anyone can create (no existing lock to check).
			allow create: if true;

			// Update rules — allowed when any of the following holds:
			//   1. The stored note has no lock or the lock is null.
			//   2. The stored lock has expired (TTL grace period).
			//   3. The incoming write clears the lock (release). We can't
			//      verify the releaser is the real holder without Auth,
			//      so we trust the client; the UI only offers the release
			//      button to the actual holder.
			//   4. The incoming lock's `holder` matches the stored lock's
			//      `holder` — same-owner heartbeat or content write
			//      (content writes use merge:true and never touch lock,
			//      so `request.resource.data.lock` equals the stored lock
			//      on content writes).
			allow update: if
				!('lock' in resource.data)
				|| resource.data.lock == null
				|| resource.data.lock.expiresAtMs < request.time.toMillis()
				|| request.resource.data.lock == null
				|| (
					request.resource.data.lock != null
					&& request.resource.data.lock.holder == resource.data.lock.holder
				);

			allow delete: if true;
		}

		match /notes_dana/{guid} {
			allow read: if true;

			// New note: anyone can create (no existing lock to check).
			allow create: if true;

			// Update rules — allowed when any of the following holds:
			//   1. The stored note has no lock or the lock is null.
			//   2. The stored lock has expired (TTL grace period).
			//   3. The incoming write clears the lock (release). We can't
			//      verify the releaser is the real holder without Auth,
			//      so we trust the client; the UI only offers the release
			//      button to the actual holder.
			//   4. The incoming lock's `holder` matches the stored lock's
			//      `holder` — same-owner heartbeat or content write
			//      (content writes use merge:true and never touch lock,
			//      so `request.resource.data.lock` equals the stored lock
			//      on content writes).
			allow update: if
				!('lock' in resource.data)
				|| resource.data.lock == null
				|| resource.data.lock.expiresAtMs < request.time.toMillis()
				|| request.resource.data.lock == null
				|| (
					request.resource.data.lock != null
					&& request.resource.data.lock.holder == resource.data.lock.holder
				);

			allow delete: if true;
		}

		// Cross-device app settings (e.g. tab notebooks). Same cooperative
		// trust model as notes — open until Phase 5 lands Auth/App Check.
		match /appSettings-chunseek/{id} {
			allow read, write: if true;
		}

		// Cross-device app settings (e.g. tab notebooks). Same cooperative
		// trust model as notes — open until Phase 5 lands Auth/App Check.
		match /appSettings-dana/{id} {
			allow read, write: if true;
		}
	}
}
